---
import './assets/scss/styles.scss'
import { Header, Footer, Modal } from '@/components/layout'
import Bg from './components/Bg.astro'

const version = Math.random().toString(16).slice(10)

const styles: string[] = [
  // '/assets/css/aos.min.css',
  '/assets/css/swiper.min.css',
  '/assets/css/fancybox.min.css',
]

const scripts: string[] = [
  // '/assets/js/aos.min.js',
  '/assets/js/swiper.min.js',
  '/assets/js/fancybox.min.js',
  `/assets/js/app.js?v=${version}`,
]

interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Site description" />
    <meta property="og:title" content="" />
    <meta property="og:description" content="" />
    <meta name="theme-color" content="#FFFFFF" />
    <meta name="application-name" content="" />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="icon" type="image/x-icon" href="favicon.ico" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="apple-touch-icon-180x180.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="192x192"
      href="apple-touch-icon-192x192.png"
    />
    <link rel="stylesheet" href="/assets/fonts/stylesheet.css" />
    {styles.map((style) => <link rel="stylesheet" href={style} />)}
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <div id="app">
      <slot name="header" />

      <div class="app-content">
        <!-- Header -->
        <Header />
        <!-- Main -->
        <slot />
      </div>

      <!-- Footer -->
      <Footer />
      <!-- Modal -->
      <Modal />
      <slot name="footer" />

      <!-- Backgrounds -->
      <Bg />
    </div>
    <!-- Scripts -->
    {scripts.map((script) => <script src={script} />)}
  </body>
</html>
