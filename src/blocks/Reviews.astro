---
import { Section, H2, H3, H4, H5, P, BgImg, Image, Button } from 'ui'
import { Icon } from 'astro-icon/components'

const { is_main = false } = Astro.props
---

<!-- Reviews -->
<Section name="reviews">
  <div class="reviews__header">
    <H5>ОТЗЫВЫ НАШИХ КЛИЕНТОВ </H5>
    <H2><strong>РЕЗУЛЬТАТ</strong>, КОТОРЫЙ ГОВОРИТ САМ ЗА СЕБЯ</H2>
  </div>

  <div class="wrapper">
    <div class="reviews__swiper">
      <div class="swiper">
        <div class="swiper-wrapper">
          {
            Array.from({ length: 6 }).map((_, i) => (
              <div
                class="swiper-slide reviews__card"
                data-fancybox="reviews"
                data-src="/assets/img/reviews/1.png"
              >
                <div class="reviews__card-img">
                  <Image src="reviews/1.png" />
                </div>
                <div class="reviews__card-play">
                  <Icon name="material-symbols:play-circle-outline-rounded" />
                </div>
              </div>
            ))
          }
        </div>
      </div>
      <div class="reviews__swiper-nav">
        <div class="btn-prev"></div>
        <div class="btn-next"></div>
      </div>
    </div>

    <div class="reviews__platforms">
      <p class="reviews__platforms-desc">
        Благодарим всех кто оставляет отзывы о нас в мессенджерах и на
        площадках. Мы ценим каждый ваш отзыв!
      </p>

      <div class="reviews__platforms-list">
        <a href="#" class="reviews__platform reviews__platform--all">
          <span class="reviews__platform-name">СМОТРЕТЬ ВСЕ ОТЗЫВЫ</span>
          <span class="reviews__platform-arrow">
            <svg
              width="18"
              height="18"
              viewBox="0 0 18 18"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M17.6169 0.999765C17.6169 0.447481 17.1692 -0.000234596 16.6169 -0.000234849L7.61693 -0.000234049C7.06465 -0.000234386 6.61693 0.447481 6.61693 0.999766C6.61693 1.55205 7.06465 1.99977 7.61693 1.99977L15.6169 1.99977L15.6169 9.99977C15.6169 10.552 16.0646 10.9998 16.6169 10.9998C17.1692 10.9998 17.6169 10.5521 17.6169 9.99977L17.6169 0.999765ZM0.707031 16.9097L1.41414 17.6168L17.324 1.70687L16.6169 0.999766L15.9098 0.292659L-7.55191e-05 16.2026L0.707031 16.9097Z"
                fill="currentColor"></path>
            </svg>
          </span>
        </a>
        <a href="#" class="reviews__platform reviews__platform--yandex">
          <span class="reviews__platform-name">ОТЗЫВЫ О НАС НА YANDEX</span>
          <span class="reviews__platform-arrow">
            <svg
              width="18"
              height="18"
              viewBox="0 0 18 18"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M17.6169 0.999765C17.6169 0.447481 17.1692 -0.000234596 16.6169 -0.000234849L7.61693 -0.000234049C7.06465 -0.000234386 6.61693 0.447481 6.61693 0.999766C6.61693 1.55205 7.06465 1.99977 7.61693 1.99977L15.6169 1.99977L15.6169 9.99977C15.6169 10.552 16.0646 10.9998 16.6169 10.9998C17.1692 10.9998 17.6169 10.5521 17.6169 9.99977L17.6169 0.999765ZM0.707031 16.9097L1.41414 17.6168L17.324 1.70687L16.6169 0.999766L15.9098 0.292659L-7.55191e-05 16.2026L0.707031 16.9097Z"
                fill="currentColor"></path>
            </svg>
          </span>
        </a>
        <a href="#" class="reviews__platform reviews__platform--2gis">
          <span class="reviews__platform-name">ОТЗЫВЫ О НАС НА 2GIS</span>
          <span class="reviews__platform-arrow">
            <svg
              width="18"
              height="18"
              viewBox="0 0 18 18"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M17.6169 0.999765C17.6169 0.447481 17.1692 -0.000234596 16.6169 -0.000234849L7.61693 -0.000234049C7.06465 -0.000234386 6.61693 0.447481 6.61693 0.999766C6.61693 1.55205 7.06465 1.99977 7.61693 1.99977L15.6169 1.99977L15.6169 9.99977C15.6169 10.552 16.0646 10.9998 16.6169 10.9998C17.1692 10.9998 17.6169 10.5521 17.6169 9.99977L17.6169 0.999765ZM0.707031 16.9097L1.41414 17.6168L17.324 1.70687L16.6169 0.999766L15.9098 0.292659L-7.55191e-05 16.2026L0.707031 16.9097Z"
                fill="currentColor"></path>
            </svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</Section>

<style lang="scss" is:global>
  @use 'scss/helpers' as *;

  .reviews {
    position: relative;

    .container {
      gap: rem(40);

      @include media('lg') {
        gap: rem(30);
      }
    }

    &__header {
      display: flex;
      flex-direction: column;
      gap: rem(10);
    }

    .wrapper {
      padding-bottom: rem(80);
      width: 100%;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: 1fr;
      gap: rem(40) rem(20);

      @include media('xl') {
        grid-template-columns: repeat(3, 1fr);
      }
      @include media('lg') {
        padding-bottom: 0;
      }
    }

    &__swiper {
      position: relative;
      height: rem(565);
      grid-column-start: span 3;
      display: flex;
      flex-direction: column;
      gap: rem(30);

      @include media('xl') {
        grid-column-start: span 2;
      }

      @include media('lg') {
        grid-column-start: span 4;
        height: auto;
      }

      .swiper {
        width: 100%;
        height: 100%;

        @include media('lg') {
          height: rem(500);
        }
        @include media('sm') {
          height: rem(440);
        }
      }

      &-nav {
        position: absolute;
        top: calc(100% + rem(40));
        display: flex;
        gap: rem(12);

        @include media('lg') {
          position: static;
          top: auto;
        }

        .btn-prev,
        .btn-next {
          width: rem(180);
          height: rem(44);
          background: #c36b3d;
          color: #fff;
          border-radius: rem(10);
          display: flex;
          align-items: center;
          justify-content: center;
          cursor: pointer;
          transition: 0.3s ease;
          position: relative;

          &::after {
            content: '';
            width: rem(100);
            height: 1px;
            background: currentColor;
            position: absolute;
          }

          &::before {
            content: '';
            width: rem(8);
            height: rem(8);
            border-top: 1px solid currentColor;
            border-right: 1px solid currentColor;
            position: absolute;
          }

          &:hover {
            background: darken(#c36b3d, 10%);
          }

          &.swiper-button-disabled {
            color: #000;
            background: rgba(255, 255, 255, 0.4);
            pointer-events: none;
          }
        }

        .btn-prev {
          &::before {
            transform: rotate(-135deg);
            left: rem(40);
          }
          &::after {
            left: rem(40);
          }
        }

        .btn-next {
          &::before {
            transform: rotate(45deg);
            right: rem(40);
          }
          &::after {
            right: rem(40);
          }
        }
      }
    }

    &__platforms {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      gap: rem(30);

      @include media('lg') {
        grid-column-start: span 4;
        flex-direction: row;
        align-items: center;
        flex-wrap: wrap;
      }

      &-desc {
        letter-spacing: 0.02em;
        line-height: 1.4;
        opacity: 0.8;

        @include media('lg') {
          width: 100%;
        }
      }

      &-list {
        display: flex;
        flex-direction: column;
        gap: rem(30);
        width: 100%;

        @include media('sm') {
          gap: rem(20);
        }
      }
    }

    &__platform {
      width: 100%;
      height: rem(36);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: rem(8);
      color: #fff;

      &-name {
        height: 100%;
        background: red;
        border-radius: rem(8);
        flex-grow: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        letter-spacing: 8%;
      }

      &-arrow {
        width: rem(36);
        height: rem(36);
        border: 1px solid currentColor;
        border-radius: rem(8);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s ease;

        svg {
          transition: 0.3s ease;
        }
      }

      &:hover {
        .reviews__platform-arrow svg {
          transform: rotate(45deg);
        }
      }

      &--all {
        .reviews__platform-name {
          background: linear-gradient(222deg, #af3033 0.06%, #491415 100%);
        }

        .reviews__platform-arrow {
          color: #c86834;
        }
      }

      &--yandex {
        .reviews__platform-name {
          background: linear-gradient(221deg, #e9c740 0%, #837024 100%);
        }

        .reviews__platform-arrow {
          color: #e9c740;
        }
      }

      &--2gis {
        .reviews__platform-name {
          background: linear-gradient(232deg, #30af61 0%, #144928 100%);
        }

        .reviews__platform-arrow {
          color: #30af61;
        }
      }
    }

    &__card {
      position: relative;
      width: 100%;
      border: 1px solid rgba(255, 255, 255, 0.15);
      border-radius: rem(35);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      cursor: pointer;

      @include media('sm') {
        border-radius: rem(20);
      }

      &::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(
          top,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 1) 100%
        );
        pointer-events: none;
      }

      &-img {
        width: 100%;
        height: 100%;

        img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          object-position: center;
          border-radius: inherit;
        }
      }

      &-play {
        position: absolute;
        z-index: 2;
        opacity: 0;
        transition: 0.2s ease;

        svg {
          width: rem(58);
          height: rem(58);
        }
      }

      &:hover {
        .reviews__card-play {
          opacity: 1;
        }
      }
    }
  }
</style>
