---
import { Section, H2, H3, H4, H5, P, Image, Icon, Button } from 'ui'

const services = [
  {
    title: 'ДЕТЕЙЛИНГ',
    list: [
      'Детейлинг химчистка салона',
      'Детейлинг подкапотного пространства',
      'Детейлинг подвески с арками',
      'Детейлинг подвески с арками',
    ],
    img: 'services/card-1.png',
  },
  {
    title: 'ОКЛЕЙКА',
    list: [
      'Оклейка антигравийной пленкой',
      'Оклейка виниловой пленкой',
      'Оклейка элементов черный глянец',
      'Бронь стеклянных элементов',
    ],
    img: 'services/card-2.png',
  },
  {
    title: 'ПОЛИРОВКА',
    list: [
      'Полировка кузова авто',
      'Полировка деталей салона',
      'Полировка мото техники',
    ],
    img: null,
  },
  {
    title: 'ПОКРЫТИЕ',
    list: [
      'Керамическое покрытие кузова',
      'Керамическое покрытие салона',
      'Антидождь',
      'Керамическое покрытие дисков',
    ],
    img: null,
  },
  {
    title: 'ДРУГИЕ РАБОТЫ',
    list: [
      'Перешив-восстановление салона',
      'Перешив руля',
      'Звездное небо',
      'Шумоизоляция салона',
      'Изготовление и ламинация карбоновых элементов',
      'Блек пакет и дооснащение на Мерседес G63',
    ],
    img: null,
  },
]
---

<!-- Services -->
<Section name="services">
  <div class="services__header">
    <H5>НАШИ УСЛУГИ</H5>
    <H2><strong>КАЧЕСТВЕННЫЕ</strong> УСЛУГИ Для вашего авто</H2>
  </div>

  <div class="services__list">
    {
      services.map((s) => (
        <div class="services__card">
          <div class="services__card-content">
            <H4 class="services__card-title">{s.title}</H4>
            <ul class="services__card-list group text-p">
              {s.list.map((l) => (
                <li>{l}</li>
              ))}
            </ul>
          </div>
          {s.img && (
            <div class="services__card-img">
              <Image src={s.img} />
            </div>
          )}
        </div>
      ))
    }
  </div>
</Section>

<style lang="scss" is:global>
  @use 'scss/helpers' as *;

  .services {
    position: relative;

    .container {
      gap: rem(50);

      @include media('lg') {
        gap: rem(30);
      }
    }

    &__header {
      display: flex;
      flex-direction: column;
      gap: rem(10);
    }

    &__list {
      width: 100%;
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: rem(30) rem(20);

      @include media('lg') {
        grid-template-columns: repeat(2, 1fr);
        gap: rem(15);
      }

      @include media('sm') {
        grid-template-columns: 1fr;
        gap: rem(12);
      }
    }

    &__card {
      position: relative;
      min-height: rem(270);
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: rem(20);
      padding: rem(24);
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      overflow: hidden;

      @include media('sm') {
        padding: rem(20);
        min-height: auto;
      }

      &:nth-child(1),
      &:nth-child(2) {
        grid-column: span 3;

        @include media('lg') {
          grid-column: span 1;
        }
      }

      &:nth-child(3),
      &:nth-child(4),
      &:nth-child(5) {
        grid-column: span 2;

        @include media('lg') {
          grid-column: span 1;
        }

        @include media('sm') {
          min-height: auto;
        }
      }

      &-content {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        gap: rem(30);

        @include media('sm') {
          gap: rem(15);
        }
      }

      &-list {
        gap: rem(10);
      }

      &-img {
        position: absolute;
        top: 0;
        right: 0;
        width: 60%;
        height: 100%;
        pointer-events: none;
        z-index: 1;

        @include media('lg') {
          display: none;
        }

        img {
          width: 100%;
          height: 100%;
          object-fit: contain;
          object-position: right top;
        }
      }
    }
  }
</style>
