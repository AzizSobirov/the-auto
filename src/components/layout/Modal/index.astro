---
import { H3, P, Button, Icon, Image } from 'ui'
---

<div class="modal-overlay">
  <!-- Callback Modal -->
  <div class="modal" data-template="callback">
    <div class="modal__content">
      <div class="modal__close" data-modal="close">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M18 6L6 18M6 6L18 18"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>

      <div class="modal__header">
        <div class="modal__title">Запишитесь на консультацию</div>
        <p class="modal__desc">
          Оставьте заявку, и наш специалист свяжется с вами в течение 15 минут
        </p>
      </div>

      <form class="modal__form the-form">
        <div class="modal__field">
          <input type="text" name="name" placeholder="Ваше имя" required />
        </div>
        <div class="modal__field">
          <input
            type="tel"
            name="phone"
            placeholder="+7 (___) ___-__-__"
            required
          />
        </div>

        <Button class="modal__submit">Отправить заявку</Button>

        <div class="modal__privacy">
          Отправляя заявку, вы соглашаетесь с <br />
          <a href="#">Политикой обработки персональных данных</a>
        </div>
      </form>

      <div class="modal__footer">
        <div class="modal__footer-text">
          Или свяжитесь с нами напрямую:
          <a href="tel:+79112332222" class="modal__footer-phone"
            >+7 (911) 233-22-22</a
          >
        </div>

        <div class="modal__socials">
          <a href="#" target="_blank" title="Telegram">
            <Icon src="telegram.svg" />
          </a>
          <a href="#" target="_blank" title="VK">
            <Icon src="vk.svg" />
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Project Modal -->
  <div class="modal modal--project" data-template="project">
    <div class="modal__content modal__content--project">
      <div class="modal__close" data-modal="close">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M18 6L6 18M6 6L18 18"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>

      <!-- Left: image + nav below -->
      <div class="modal__project-left">
        <div class="modal__project-img">
          <img src="" alt="" id="project-modal-img" />
        </div>
        <div class="modal__project-nav">
          <div class="modal__project-prev btn-arrow">
            <svg
              width="21"
              height="8"
              viewBox="0 0 21 8"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              ><path
                d="M20.5 3.18213C20.7761 3.18213 21 3.40599 21 3.68213C21 3.95827 20.7761 4.18213 20.5 4.18213V3.68213V3.18213ZM0.146446 4.03568C-0.0488155 3.84042 -0.0488155 3.52384 0.146446 3.32858L3.32843 0.146595C3.52369 -0.0486672 3.84027 -0.0486672 4.03553 0.146595C4.2308 0.341857 4.2308 0.65844 4.03553 0.853702L1.20711 3.68213L4.03553 6.51056C4.2308 6.70582 4.2308 7.0224 4.03553 7.21766C3.84027 7.41293 3.52369 7.41293 3.32843 7.21766L0.146446 4.03568ZM20.5 3.68213V4.18213L0.5 4.18213V3.68213V3.18213L20.5 3.18213V3.68213Z"
                fill="currentColor"></path></svg
            >
          </div>
          <div class="modal__project-next btn-arrow">
            <svg
              width="21"
              height="8"
              viewBox="0 0 21 8"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              ><path
                d="M0.5 3.18213C0.223858 3.18213 0 3.40599 0 3.68213C0 3.95827 0.223858 4.18213 0.5 4.18213V3.68213V3.18213ZM20.8536 4.03568C21.0488 3.84042 21.0488 3.52384 20.8536 3.32858L17.6716 0.146595C17.4763 -0.0486672 17.1597 -0.0486672 16.9645 0.146595C16.7692 0.341857 16.7692 0.65844 16.9645 0.853702L19.7929 3.68213L16.9645 6.51056C16.7692 6.70582 16.7692 7.0224 16.9645 7.21766C17.1597 7.41293 17.4763 7.41293 17.6716 7.21766L20.8536 4.03568ZM0.5 3.68213V4.18213L20.5 4.18213V3.68213V3.18213L0.5 3.18213V3.68213Z"
                fill="currentColor"></path></svg
            >
          </div>
        </div>
      </div>

      <!-- Right: info + cta -->
      <div class="modal__project-body">
        <div class="modal__project-info">
          <H3 class="modal__project-title" id="project-modal-title" />
          <P class="modal__project-service" id="project-modal-service" />
          <P class="modal__project-desc" id="project-modal-desc" />
        </div>

        <div class="modal__project-footer">
          <a
            href="#"
            class="modal__project-cta"
            data-modal="close"
            data-modal-open="callback"
          >
            <span class="modal__project-cta-name">ОНЛАЙН ЗАПИСЬ</span>
            <span class="modal__project-cta-arrow">
              <svg
                width="18"
                height="18"
                viewBox="0 0 18 18"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M17.6169 0.999765C17.6169 0.447481 17.1692 -0.000234596 16.6169 -0.000234849L7.61693 -0.000234049C7.06465 -0.000234386 6.61693 0.447481 6.61693 0.999766C6.61693 1.55205 7.06465 1.99977 7.61693 1.99977L15.6169 1.99977L15.6169 9.99977C15.6169 10.552 16.0646 10.9998 16.6169 10.9998C17.1692 10.9998 17.6169 10.5521 17.6169 9.99977L17.6169 0.999765ZM0.707031 16.9097L1.41414 17.6168L17.324 1.70687L16.6169 0.999766L15.9098 0.292659L-7.55191e-05 16.2026L0.707031 16.9097Z"
                  fill="currentColor"></path>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Success Modal -->
  <div class="modal" data-template="success">
    <div class="modal__content modal__content--success">
      <div class="modal__close" data-modal="close">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M18 6L6 18M6 6L18 18"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>

      <div class="modal__success-icon">
        <svg
          width="64"
          height="64"
          viewBox="0 0 64 64"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <circle cx="32" cy="32" r="32" fill="#005A87" fill-opacity="0.1"
          ></circle>
          <path
            d="M44 24L28 40L20 32"
            stroke="#005A87"
            stroke-width="4"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>

      <div class="modal__header">
        <div class="modal__title">Спасибо за заявку!</div>
        <p class="modal__desc">
          Мы получили ваше сообщение и свяжемся с вами в ближайшее время.
        </p>
      </div>

      <Button class="modal__close-btn" data-modal="close">Закрыть</Button>
    </div>
  </div>
</div>

<style lang="scss" is:global>
  @use 'scss/helpers' as *;

  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 1000;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(8px);
    display: none;
    justify-content: center;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);

    &.show {
      opacity: 1;
      visibility: visible;
    }
  }

  .modal {
    width: 100%;
    max-width: rem(540);
    padding: rem(20);
    display: none;
    transform: translateY(rem(20));
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);

    &.show {
      display: flex;
      transform: translateY(0);
      opacity: 1;
    }

    &__content {
      position: relative;
      width: 100%;
      background: #fff;
      border-radius: rem(20);
      padding: rem(32);
      color: #000;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);

      @include media('sm') {
        padding: rem(32) rem(24);
      }

      &--success {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
    }

    &__close {
      position: absolute;
      top: rem(16);
      right: rem(16);
      cursor: pointer;
      color: var(--gray);
      transition: color 0.3s ease;

      &:hover {
        color: #000;
      }
    }

    &__header {
      margin-bottom: rem(32);
    }

    &__title {
      font-size: rem(32);
      font-weight: 700;
      margin-bottom: rem(12);
      line-height: 1.2;

      @include media('sm') {
        font-size: rem(24);
      }
    }

    &__desc {
      font-size: rem(16);
      color: var(--gray);
      line-height: 1.5;
    }

    &__form {
      display: flex;
      flex-direction: column;
      gap: rem(16);
      margin-bottom: rem(32);
    }

    &__field {
      input {
        width: 100%;
        height: rem(56);
        padding: 0 rem(20);
        background: #f5f5f5;
        border: 1px solid transparent;
        border-radius: rem(12);
        font-size: rem(16);
        transition: all 0.3s ease;

        &:focus {
          background: #fff;
          border-color: var(--primary);
          outline: none;
        }
      }
    }

    &__submit {
      width: 100% !important;
      height: rem(60) !important;
      background: var(--primary);
      font-weight: 700;
      font-size: rem(16);
      border-radius: 9999px !important;
      color: #fff;
      transition: var(--transition-ease);
      margin-top: rem(8);

      &:hover {
        background: var(--primary-hover);
      }

      &:active {
        transform: scale(0.95);
      }

      &:disabled {
        opacity: 0.4;
        cursor: not-allowed;
      }
    }

    &__privacy {
      font-size: rem(12);
      color: var(--gray);
      text-align: center;
      line-height: 1.4;

      a {
        color: var(--primary);
        text-decoration: underline;
      }
    }

    &__footer {
      border-top: 1px solid #eee;
      padding-top: rem(24);
      display: flex;
      justify-content: space-between;
      align-items: center;

      @include media('sm') {
        flex-direction: column;
        gap: rem(20);
        text-align: center;
      }

      &-text {
        font-size: rem(14);
        color: var(--gray);
      }

      &-phone {
        display: block;
        font-size: rem(18);
        font-weight: 600;
        color: #000;
        text-decoration: none;
        margin-top: rem(4);
      }
    }

    &__socials {
      display: flex;
      gap: rem(12);

      a {
        --icon-size: #{rem(24)};
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        transition: transform 0.3s ease;

        &:hover {
          transform: translateY(rem(-2));
        }
      }
    }

    &__success-icon {
      margin-bottom: rem(24);
    }

    &__close-btn {
      width: auto !important;
      min-width: rem(160);
      background: var(--primary);
      font-weight: 700;
      font-size: rem(14);
      border-radius: 9999px !important;
      color: #fff;
      transition: var(--transition-ease);

      &:hover {
        background: var(--primary-hover);
      }

      &:active {
        transform: scale(0.95);
      }
    }

    // ── Project modal ──────────────────────────────────────
    &--project {
      max-width: rem(950);

      @include media('sm') {
        padding: rem(12);
      }
    }

    &__content--project {
      padding: rem(20) !important;
      background: #051704;
      color: #fff;
      padding: 0;
      display: flex;
      align-items: stretch;
      overflow: hidden;
      border-radius: rem(20);
      border: 1px solid rgba(255, 255, 255, 0.15);

      @include media('lg') {
        flex-direction: column;
        max-height: 90vh;
        overflow-y: auto;
      }
      @include media('sm') {
        padding: rem(10) !important;
      }

      .modal__close {
        color: rgba(255, 255, 255, 1);
        z-index: 2;

        @include media('lg') {
          padding: 4px;
          background: rgba(0, 0, 0, 0.5);
          backdrop-filter: blur(5px);
          border-radius: 50%;
        }

        &:hover {
          color: #fff;
        }
      }
    }

    &__project-left {
      position: relative;
      height: rem(565);
      width: rem(430);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      border-radius: rem(12);
      flex-shrink: 0;

      @include media('lg') {
        width: 100%;
        max-height: 50vh;
      }
      @include media('sm') {
        max-height: 40vh;
      }
    }

    &__project-img {
      flex: 1;
      width: 100%;
      height: 100%;
      overflow: hidden;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        transition: opacity 0.3s ease;
      }
    }

    &__project-body {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: rem(20);
      padding: rem(20);

      @include media('sm') {
        padding: rem(20) 0;
        gap: rem(15);
      }
    }

    &__project-info {
      display: flex;
      flex-direction: column;
      gap: rem(12);
      padding-right: rem(28);

      @include media('sm') {
        padding-right: 0;
      }
    }

    &__project-service {
      letter-spacing: 0.03em;
    }

    &__project-desc {
      margin-top: rem(20);
      letter-spacing: 0.03em;
      line-height: 1.3;

      @include media('sm') {
        margin-top: rem(10);
      }
    }

    &__project-footer {
      display: flex;
      align-items: center;
      gap: rem(12);
    }

    &__project-cta {
      margin-top: rem(20);
      height: rem(35);
      display: flex;
      align-items: center;
      gap: rem(8);
      color: #fff;
      text-decoration: none;
      flex-shrink: 0;

      &-name {
        height: 100%;
        width: rem(215);
        background: #c36b3d;
        border-radius: rem(10);
        display: flex;
        align-items: center;
        letter-spacing: 8%;
        text-align: center;
        display: flex;
        justify-content: center;
      }

      &-arrow {
        width: rem(35);
        height: rem(35);
        border: 1px solid #c36b3d;
        border-radius: rem(10);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #c36b3d;
        transition: 0.3s ease;

        svg {
          transition: 0.3s ease;
        }
      }

      &:hover {
        .modal__project-cta-name {
          background: darken(#c36b3d, 10%);
        }
        .modal__project-cta-arrow svg {
          transform: rotate(45deg);
        }
      }
    }

    &__project-nav {
      position: absolute;
      bottom: rem(20);
      left: rem(20);
      right: rem(20);
      display: flex;
      gap: rem(20);

      @include media('sm') {
        bottom: rem(10);
        left: rem(10);
        right: rem(10);
        gap: rem(12);
      }

      .btn-arrow {
        flex: 1;
        height: rem(35);
        background: #c36b3d;
        border-radius: rem(10);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.3s ease;
        position: relative;

        &:hover {
          background: darken(#c36b3d, 10%);
        }

        &.disabled {
          color: #3a3a3a;
          background: #8c8c8c;
          pointer-events: none;
        }

        &::after {
          content: '';
          width: rem(80);
          height: 1px;
          background: currentColor;
          position: absolute;
        }

        &::before {
          content: '';
          width: rem(8);
          height: rem(8);
          border-top: 1px solid currentColor;
          border-right: 1px solid currentColor;
          position: absolute;
        }

        svg {
          display: none;
        }
      }

      .modal__project-prev {
        &::before {
          transform: rotate(-135deg);
          left: 35%;
        }
        &::after {
          left: 35%;
          width: rem(60);
        }
        @include media('sm') {
          &::before,
          &::after {
            left: 32%;
          }
        }
      }

      .modal__project-next {
        &::before {
          transform: rotate(45deg);
          right: 35%;
        }
        &::after {
          right: 35%;
          width: rem(60);
        }
        @include media('sm') {
          &::before,
          &::after {
            right: 32%;
          }
        }
      }
    }
  }
</style>
