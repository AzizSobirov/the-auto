---
import { H3, P, Button, Icon, Image } from 'ui'
---

<div class="modal-overlay">
  <!-- Callback Modal -->
  <div class="modal" data-template="callback">
    <div class="modal__content">
      <div class="modal__close" data-modal="close">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M18 6L6 18M6 6L18 18"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>

      <div class="modal__header">
        <div class="modal__title">Запишитесь на консультацию</div>
        <p class="modal__desc">
          Оставьте заявку, и наш специалист свяжется с вами в течение 15 минут
        </p>
      </div>

      <form class="modal__form the-form">
        <div class="modal__field">
          <input type="text" name="name" placeholder="Ваше имя" required />
        </div>
        <div class="modal__field">
          <input
            type="tel"
            name="phone"
            placeholder="+7 (___) ___-__-__"
            required
          />
        </div>

        <Button class="modal__submit">Отправить заявку</Button>

        <div class="modal__privacy">
          Отправляя заявку, вы соглашаетесь с <br />
          <a href="#">Политикой обработки персональных данных</a>
        </div>
      </form>

      <div class="modal__footer">
        <div class="modal__footer-text">
          Или свяжитесь с нами напрямую:
          <a href="tel:+79112332222" class="modal__footer-phone"
            >+7 (911) 233-22-22</a
          >
        </div>

        <div class="modal__socials">
          <a href="#" class="modal__socials-item" target="_blank">
            <svg
              width="47"
              height="47"
              viewBox="0 0 47 47"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <rect width="47" height="47" rx="15" fill="#0098D9"></rect>
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M16.384 26.325C16.4371 26.3415 16.4913 26.3543 16.5462 26.3633C16.8939 27.1882 17.2396 28.014 17.5834 28.8405C18.2016 30.3278 18.8246 31.8596 18.961 32.3001C19.1319 32.8421 19.3113 33.2108 19.5079 33.4632C19.6099 33.5919 19.7267 33.7058 19.8643 33.7924C19.9366 33.8365 20.0132 33.873 20.0929 33.9013C20.4861 34.0497 20.845 33.9879 21.0699 33.9124C21.2019 33.8672 21.3275 33.8048 21.4435 33.7268L21.4496 33.7243L24.9225 31.5441L28.9349 34.64C28.9939 34.6853 29.0578 34.7237 29.1267 34.755C29.6084 34.9654 30.0754 35.0396 30.5153 34.9802C30.9528 34.9184 31.3006 34.734 31.5599 34.5249C31.8574 34.283 32.0947 33.9746 32.253 33.6241L32.2641 33.5969L32.2678 33.587L32.2702 33.582V33.5796L32.2715 33.5783C32.2916 33.5247 32.308 33.4697 32.3206 33.4137L35.9828 14.8226C35.9929 14.7629 35.9987 14.7025 36 14.642C36 14.0975 35.796 13.5791 35.318 13.266C34.9075 12.9975 34.4516 12.9852 34.1628 13.0074C33.8531 13.0322 33.5655 13.1089 33.3726 13.1708C33.2648 13.2058 33.1582 13.2446 33.0531 13.2871L33.0395 13.2933L12.4994 21.4053L12.4969 21.4065C12.4273 21.4319 12.3588 21.4604 12.2917 21.4919C12.1288 21.5655 11.9725 21.6533 11.8247 21.7542C11.5457 21.946 10.903 22.4731 11.0124 23.3442C11.0984 24.0371 11.5703 24.464 11.8591 24.6694C12.0164 24.782 12.1664 24.8624 12.277 24.9157C12.3261 24.9404 12.4318 24.9825 12.4773 25.0023L12.4896 25.006L16.384 26.325ZM33.7585 15.0008H33.756L33.724 15.0144L13.1593 23.1376L13.1274 23.15L13.1151 23.1537C13.0774 23.1683 13.0405 23.1849 13.0045 23.2032C13.0388 23.2226 13.0741 23.2404 13.1102 23.2564L16.9714 24.5655C17.0396 24.5909 17.1054 24.6224 17.1681 24.6595L29.9205 17.1426L29.9328 17.1365C29.9826 17.1066 30.0335 17.0785 30.0852 17.0523C30.1737 17.0065 30.315 16.9397 30.4748 16.8902C30.5854 16.8556 30.9135 16.7578 31.2674 16.8729C31.4555 16.932 31.6231 17.0433 31.7509 17.1942C31.8788 17.345 31.9617 17.5292 31.99 17.7254C32.0358 17.8971 32.0371 18.0778 31.9937 18.2501C31.9077 18.5903 31.6717 18.8551 31.4567 19.0581C31.2724 19.2313 28.8809 21.5525 26.5226 23.8441L23.3114 26.9622L22.74 27.519L29.9562 33.0896C30.0536 33.1305 30.1594 33.1475 30.2646 33.1391C30.3176 33.1317 30.3675 33.1094 30.4084 33.0747C30.4582 33.0323 30.5009 32.9822 30.535 32.9262L30.5375 32.925L34.089 14.8932C33.9773 14.9208 33.8677 14.9564 33.7609 14.9996L33.7585 15.0008ZM23.3606 30.3365L21.9203 29.2253L21.5713 31.4587L23.3606 30.3365ZM20.5992 27.0204L22.0309 25.6284L25.242 22.5078L26.4378 21.3471L18.4252 26.0701L18.4682 26.1716C18.9736 27.3736 19.4734 28.5779 19.9675 29.7846L20.3153 27.5574C20.3471 27.3509 20.4471 27.1625 20.5992 27.0204Z"
                fill="white"></path>
            </svg>
          </a>
          <a href="#" class="modal__socials-item" target="_blank">
            <svg
              width="47"
              height="47"
              viewBox="0 0 47 47"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <rect
                width="47"
                height="47"
                rx="15"
                fill="url(#paint0_linear_66_871)"></rect>
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M23.7686 35.9287C21.3151 35.9287 20.175 35.5689 18.1932 34.13C16.9396 35.7488 12.9699 37.0138 12.7968 34.8495C12.7968 33.2248 12.4386 31.8518 12.0327 30.353C11.5492 28.5064 11 26.45 11 23.4703C11 16.3538 16.8142 11 23.7029 11C30.5976 11 35.9999 16.6176 35.9999 23.5363C36.0231 30.3479 30.5507 35.8923 23.7686 35.9287ZM23.8701 17.1512C20.5153 16.9774 17.9006 19.3096 17.3216 22.9667C16.8441 25.9944 17.6917 29.6815 18.414 29.8734C18.7602 29.9573 19.6318 29.2498 20.175 28.7043C21.0732 29.3275 22.1192 29.7018 23.2075 29.7894C26.6836 29.9574 29.6538 27.2995 29.8872 23.8121C30.0231 20.3173 27.3467 17.3572 23.8701 17.1572V17.1512Z"
                fill="white"></path>
              <defs>
                <linearGradient
                  id="paint0_linear_66_871"
                  x1="5.53881"
                  y1="35.7452"
                  x2="47"
                  y2="23.5"
                  gradientUnits="userSpaceOnUse"
                >
                  <stop stop-color="#44CCFF"></stop>
                  <stop offset="0.662" stop-color="#5533EE"></stop>
                  <stop offset="1" stop-color="#9933DD"></stop>
                </linearGradient>
              </defs>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Project Modal -->
  <div class="modal modal--project" data-template="project">
    <div class="modal__content modal__content--project">
      <div class="modal__close" data-modal="close">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M18 6L6 18M6 6L18 18"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>

      <!-- Left: image + nav below -->
      <div class="modal__project-left">
        <div class="modal__project-img">
          <img src="" alt="" id="project-modal-img" />
        </div>
        <div class="modal__project-nav">
          <div class="modal__project-prev btn-arrow">
            <svg
              width="21"
              height="8"
              viewBox="0 0 21 8"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              ><path
                d="M20.5 3.18213C20.7761 3.18213 21 3.40599 21 3.68213C21 3.95827 20.7761 4.18213 20.5 4.18213V3.68213V3.18213ZM0.146446 4.03568C-0.0488155 3.84042 -0.0488155 3.52384 0.146446 3.32858L3.32843 0.146595C3.52369 -0.0486672 3.84027 -0.0486672 4.03553 0.146595C4.2308 0.341857 4.2308 0.65844 4.03553 0.853702L1.20711 3.68213L4.03553 6.51056C4.2308 6.70582 4.2308 7.0224 4.03553 7.21766C3.84027 7.41293 3.52369 7.41293 3.32843 7.21766L0.146446 4.03568ZM20.5 3.68213V4.18213L0.5 4.18213V3.68213V3.18213L20.5 3.18213V3.68213Z"
                fill="currentColor"></path></svg
            >
          </div>
          <div class="modal__project-next btn-arrow">
            <svg
              width="21"
              height="8"
              viewBox="0 0 21 8"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              ><path
                d="M0.5 3.18213C0.223858 3.18213 0 3.40599 0 3.68213C0 3.95827 0.223858 4.18213 0.5 4.18213V3.68213V3.18213ZM20.8536 4.03568C21.0488 3.84042 21.0488 3.52384 20.8536 3.32858L17.6716 0.146595C17.4763 -0.0486672 17.1597 -0.0486672 16.9645 0.146595C16.7692 0.341857 16.7692 0.65844 16.9645 0.853702L19.7929 3.68213L16.9645 6.51056C16.7692 6.70582 16.7692 7.0224 16.9645 7.21766C17.1597 7.41293 17.4763 7.41293 17.6716 7.21766L20.8536 4.03568ZM0.5 3.68213V4.18213L20.5 4.18213V3.68213V3.18213L0.5 3.18213V3.68213Z"
                fill="currentColor"></path></svg
            >
          </div>
        </div>
      </div>

      <!-- Right: info + cta -->
      <div class="modal__project-body">
        <div class="modal__project-info">
          <H3 class="modal__project-title" id="project-modal-title" />
          <P class="modal__project-service" id="project-modal-service" />
          <P class="modal__project-desc" id="project-modal-desc" />
        </div>

        <div class="modal__project-footer">
          <a
            href="#"
            class="modal__project-cta"
            data-modal="close"
            data-modal-open="callback"
          >
            <span class="modal__project-cta-name">ОНЛАЙН ЗАПИСЬ</span>
            <span class="modal__project-cta-arrow">
              <svg
                width="18"
                height="18"
                viewBox="0 0 18 18"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M17.6169 0.999765C17.6169 0.447481 17.1692 -0.000234596 16.6169 -0.000234849L7.61693 -0.000234049C7.06465 -0.000234386 6.61693 0.447481 6.61693 0.999766C6.61693 1.55205 7.06465 1.99977 7.61693 1.99977L15.6169 1.99977L15.6169 9.99977C15.6169 10.552 16.0646 10.9998 16.6169 10.9998C17.1692 10.9998 17.6169 10.5521 17.6169 9.99977L17.6169 0.999765ZM0.707031 16.9097L1.41414 17.6168L17.324 1.70687L16.6169 0.999766L15.9098 0.292659L-7.55191e-05 16.2026L0.707031 16.9097Z"
                  fill="currentColor"></path>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Success Modal -->
  <div class="modal" data-template="success">
    <div class="modal__content modal__content--success">
      <div class="modal__close" data-modal="close">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M18 6L6 18M6 6L18 18"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>

      <div class="modal__success-icon">
        <svg
          width="64"
          height="64"
          viewBox="0 0 64 64"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <circle cx="32" cy="32" r="32" fill="#c36b3d" fill-opacity="0.1"
          ></circle>
          <path
            d="M44 24L28 40L20 32"
            stroke="#c36b3d"
            stroke-width="4"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>

      <div class="modal__header">
        <div class="modal__title">Спасибо за заявку!</div>
        <p class="modal__desc">
          Мы получили ваше сообщение и свяжемся с вами в ближайшее время.
        </p>
      </div>

      <Button class="modal__close-btn" data-modal="close">Закрыть</Button>
    </div>
  </div>
</div>

<style lang="scss" is:global>
  @use 'scss/helpers' as *;

  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 1000;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(8px);
    display: none;
    justify-content: center;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);

    &.show {
      opacity: 1;
      visibility: visible;
    }
  }

  .modal {
    width: 100%;
    max-width: rem(540);
    padding: rem(20);
    display: none;
    transform: translateY(rem(20));
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);

    &.show {
      display: flex;
      transform: translateY(0);
      opacity: 1;
    }

    &__content {
      position: relative;
      width: 100%;
      max-width: rem(500);
      background: #051704;
      border-radius: rem(20);
      padding: rem(32);
      color: #fff;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.15);

      @include media('sm') {
        padding: rem(32) rem(24);
      }

      &--success {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
    }

    &__close {
      position: absolute;
      top: rem(16);
      right: rem(16);
      cursor: pointer;
      color: rgba(255, 255, 255, 0.6);
      transition: color 0.3s ease;

      &:hover {
        color: #fff;
      }
    }

    &__header {
      margin-bottom: rem(32);
    }

    &__title {
      font-size: rem(32);
      font-weight: 700;
      margin-bottom: rem(12);
      line-height: 1.2;

      @include media('sm') {
        font-size: rem(24);
      }
    }

    &__desc {
      font-size: rem(16);
      color: rgba(255, 255, 255, 0.6);
      line-height: 1.5;
    }

    &__form {
      display: flex;
      flex-direction: column;
      gap: rem(16);
      margin-bottom: rem(32);
    }

    &__field {
      input {
        width: 100%;
        height: rem(56);
        padding: 0 rem(20);
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: rem(12);
        font-size: rem(16);
        color: #fff;
        transition: all 0.3s ease;

        &::placeholder {
          color: rgba(255, 255, 255, 0.4);
        }

        &:focus {
          background: rgba(255, 255, 255, 0.08);
          border-color: #c36b3d;
          outline: none;
        }
      }
    }

    &__submit {
      width: 100% !important;
      height: rem(60) !important;
      background: #c36b3d;
      font-weight: 700;
      font-size: rem(18);
      border-radius: rem(15) !important;
      color: #fff;
      transition: 0.3s ease;
      margin-top: rem(8);

      &:hover {
        background: darken(#c36b3d, 10%);
      }

      &:active {
        transform: scale(0.98);
      }

      &:disabled {
        opacity: 0.4;
        cursor: not-allowed;
      }
    }

    &__privacy {
      font-size: rem(12);
      color: rgba(255, 255, 255, 0.4);
      text-align: center;
      line-height: 1.4;

      a {
        color: #c36b3d;
        text-decoration: underline;
      }
    }

    &__footer {
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      padding-top: rem(24);
      display: flex;
      justify-content: space-between;
      align-items: center;

      @include media('sm') {
        flex-direction: column;
        gap: rem(20);
        text-align: center;
      }

      &-text {
        font-size: rem(14);
        color: rgba(255, 255, 255, 0.6);
      }

      &-phone {
        display: block;
        font-size: rem(20);
        font-weight: 600;
        color: #fff;
        text-decoration: none;
        margin-top: rem(4);
      }
    }

    &__socials {
      display: flex;
      gap: rem(12);

      &-item {
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.3s ease;

        &:hover {
          transform: translateY(rem(-3));
        }

        svg {
          width: rem(40);
          height: rem(40);

          @include media('sm') {
            width: rem(36);
            height: rem(36);
          }
        }
      }
    }

    &__success-icon {
      margin-bottom: rem(24);
    }

    &__close-btn {
      width: auto !important;
      min-width: rem(160);
      background: var(--primary);
      font-weight: 700;
      font-size: rem(14);
      border-radius: 9999px !important;
      color: #fff;
      transition: var(--transition-ease);

      &:hover {
        background: var(--primary-hover);
      }

      &:active {
        transform: scale(0.95);
      }
    }

    // ── Project modal ──────────────────────────────────────
    &--project {
      max-width: rem(950) !important;

      @include media('sm') {
        padding: rem(12);
      }
    }

    &__content--project {
      padding: rem(20) !important;
      max-width: 100%;
      background: #051704;
      color: #fff;
      padding: 0;
      display: flex;
      align-items: stretch;
      overflow: hidden;
      border-radius: rem(20);
      border: 1px solid rgba(255, 255, 255, 0.15);

      @include media('lg') {
        flex-direction: column;
        max-height: 90vh;
        overflow-y: auto;
      }
      @include media('sm') {
        padding: rem(10) !important;
      }

      .modal__close {
        color: rgba(255, 255, 255, 1);
        z-index: 2;

        @include media('lg') {
          padding: 4px;
          background: rgba(0, 0, 0, 0.5);
          backdrop-filter: blur(5px);
          border-radius: 50%;
        }

        &:hover {
          color: #fff;
        }
      }
    }

    &__project-left {
      position: relative;
      height: rem(565);
      width: rem(430);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      border-radius: rem(12);
      flex-shrink: 0;

      @include media('lg') {
        width: 100%;
        max-height: 50vh;
      }
      @include media('sm') {
        max-height: 40vh;
      }
    }

    &__project-img {
      flex: 1;
      width: 100%;
      height: 100%;
      overflow: hidden;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        transition: opacity 0.3s ease;
      }
    }

    &__project-body {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: rem(20);
      padding: rem(20);

      @include media('sm') {
        padding: rem(20) 0;
        gap: rem(15);
      }
    }

    &__project-info {
      display: flex;
      flex-direction: column;
      gap: rem(12);
      padding-right: rem(28);

      @include media('sm') {
        padding-right: 0;
      }
    }

    &__project-service {
      letter-spacing: 0.03em;
    }

    &__project-desc {
      margin-top: rem(20);
      letter-spacing: 0.03em;
      line-height: 1.3;

      @include media('sm') {
        margin-top: rem(10);
      }
    }

    &__project-footer {
      display: flex;
      align-items: center;
      gap: rem(12);
    }

    &__project-cta {
      margin-top: rem(20);
      height: rem(35);
      display: flex;
      align-items: center;
      gap: rem(8);
      color: #fff;
      text-decoration: none;
      flex-shrink: 0;

      &-name {
        height: 100%;
        width: rem(215);
        background: #c36b3d;
        border-radius: rem(10);
        display: flex;
        align-items: center;
        letter-spacing: 8%;
        text-align: center;
        display: flex;
        justify-content: center;
      }

      &-arrow {
        width: rem(35);
        height: rem(35);
        border: 1px solid #c36b3d;
        border-radius: rem(10);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #c36b3d;
        transition: 0.3s ease;

        svg {
          transition: 0.3s ease;
        }
      }

      &:hover {
        .modal__project-cta-name {
          background: darken(#c36b3d, 10%);
        }
        .modal__project-cta-arrow svg {
          transform: rotate(45deg);
        }
      }
    }

    &__project-nav {
      position: absolute;
      bottom: rem(20);
      left: rem(20);
      right: rem(20);
      display: flex;
      gap: rem(20);

      @include media('sm') {
        bottom: rem(10);
        left: rem(10);
        right: rem(10);
